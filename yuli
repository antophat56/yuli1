
<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Dancing+Script:wght@500;700&display=swap');

*{box-sizing:border-box;margin:0;padding:0;}

body{
  background:#1C0D04;
  min-height:100vh;
  font-family:'Playfair Display',serif;
  overflow-x:hidden;
}

/* STARS */
.stars{position:fixed;inset:0;pointer-events:none;z-index:0;}
.star{position:absolute;border-radius:50%;background:#fff;animation:twinkle ease-in-out infinite;}
@keyframes twinkle{0%,100%{opacity:0.06;}50%{opacity:0.55;transform:scale(1.6);}}

/* PAGES */
.pages{
  position:relative;z-index:2;
  width:100%;max-width:380px;
  margin:0 auto;
}

/* ========== PAGE 1: FLORES ========== */
.pg{
  width:100%;min-height:100vh;
  display:flex;flex-direction:column;
  align-items:center;justify-content:flex-start;
  padding:36px 20px 40px;
  position:relative;
}

.badge{
  display:inline-block;
  font-family:'Dancing Script',cursive;
  font-size:11px;
  letter-spacing:0.18em;
  color:#C87840;
  text-transform:uppercase;
  margin-bottom:10px;
}

.pg-title{
  font-family:'Dancing Script',cursive;
  font-size:42px;
  font-weight:700;
  color:#F5C887;
  text-align:center;
  line-height:1.05;
  text-shadow:0 2px 18px rgba(245,200,135,0.25);
  margin-bottom:4px;
}

.pg-sub{
  font-family:'Playfair Display',serif;
  font-style:italic;
  font-size:13px;
  color:#9A6040;
  text-align:center;
  letter-spacing:0.1em;
  margin-bottom:32px;
}

/* DIVIDER */
.divider{
  display:flex;align-items:center;gap:10px;
  width:180px;margin:0 auto 30px;
}
.divider-line{flex:1;height:1px;background:linear-gradient(to right,transparent,#8B4513,transparent);}
.divider-dot{width:5px;height:5px;border-radius:50%;background:#C87840;}

/* FLOWER CARD */
.flower-card{
  background:linear-gradient(160deg,#2A1208 0%,#1C0A04 100%);
  border:1px solid #5C2810;
  border-radius:28px;
  padding:28px 20px 24px;
  width:100%;
  display:flex;flex-direction:column;
  align-items:center;
  position:relative;
  overflow:hidden;
}

.flower-card::before{
  content:'';position:absolute;inset:0;
  border-radius:28px;
  background:radial-gradient(ellipse at 50% 0%,rgba(245,200,135,0.06) 0%,transparent 70%);
  pointer-events:none;
}

.bouquet{
  animation:sway 5s ease-in-out infinite;
  transform-origin:center bottom;
  cursor:pointer;
  transition:transform 0.2s;
}
.bouquet:active{transform:scale(0.93) rotate(-3deg)!important;}
@keyframes sway{
  0%,100%{transform:rotate(-2deg) translateY(0);}
  50%{transform:rotate(2deg) translateY(-8px);}
}

.flower-hint{
  font-family:'Dancing Script',cursive;
  font-size:13px;color:#8B5030;
  margin-top:16px;
  animation:blink 2.5s ease-in-out infinite;
}
@keyframes blink{0%,100%{opacity:0.3;}50%{opacity:1;}}

/* SCROLL DOWN ARROW */
.scroll-btn{
  margin-top:28px;
  display:flex;flex-direction:column;align-items:center;gap:6px;
  cursor:pointer;
  animation:bounceDown 2s ease-in-out infinite;
}
.scroll-btn span{
  font-family:'Dancing Script',cursive;
  font-size:13px;color:#C87840;
}
.arrow-down{
  width:32px;height:32px;
  border-right:2px solid #C87840;
  border-bottom:2px solid #C87840;
  transform:rotate(45deg);
  opacity:0.7;
}
@keyframes bounceDown{
  0%,100%{transform:translateY(0);}
  50%{transform:translateY(8px);}
}

/* SEPARATOR BAND */
.sep-band{
  width:100%;
  padding:18px 20px;
  background:linear-gradient(90deg,transparent,#3D1808,transparent);
  display:flex;align-items:center;justify-content:center;
  gap:12px;
  position:relative;z-index:2;
}
.sep-text{
  font-family:'Dancing Script',cursive;
  font-size:15px;color:#F5C887;
  letter-spacing:0.08em;
}
.sep-line{flex:1;height:1px;background:linear-gradient(to right,transparent,#8B4513,transparent);}

/* ========== PAGE 2: CHOCOLATE ========== */
.choco-section{
  width:100%;
  display:flex;flex-direction:column;
  align-items:center;
  padding:36px 20px 44px;
  position:relative;
}

.choco-card{
  background:linear-gradient(160deg,#2A0E04 0%,#1A0802 100%);
  border:1px solid #6B2E0A;
  border-radius:28px;
  padding:28px 20px 24px;
  width:100%;
  display:flex;flex-direction:column;
  align-items:center;
  position:relative;
  overflow:hidden;
  cursor:pointer;
}
.choco-card::before{
  content:'';position:absolute;inset:0;border-radius:28px;
  background:radial-gradient(ellipse at 50% 0%,rgba(139,64,16,0.15) 0%,transparent 70%);
  pointer-events:none;
}

.heart-float{
  animation:heartBeat 1.7s ease-in-out infinite;
  filter:drop-shadow(0 0 12px rgba(192,57,27,0.6));
  margin-bottom:-10px;
  position:relative;z-index:3;
}
@keyframes heartBeat{
  0%,100%{transform:scale(1) translateY(0);}
  15%{transform:scale(1.2) translateY(-3px);}
  30%{transform:scale(1) translateY(0);}
  45%{transform:scale(1.1) translateY(-2px);}
}

.sparks{position:relative;height:0;width:200px;}
.spark{
  position:absolute;
  border-radius:50%;
  animation:sparkFly ease-in-out infinite;
}
@keyframes sparkFly{
  0%{opacity:0;transform:scale(0) translate(0,0);}
  45%{opacity:1;transform:scale(1.3) translate(var(--tx),var(--ty));}
  100%{opacity:0;transform:scale(0) translate(calc(var(--tx)*1.9),calc(var(--ty)*1.9));}
}

.bar-anim{
  animation:barFloat 4s ease-in-out infinite;
  position:relative;z-index:2;
}
@keyframes barFloat{
  0%,100%{transform:translateY(0) rotate(-0.5deg);}
  50%{transform:translateY(-10px) rotate(0.5deg);}
}

.steam-row{
  display:flex;gap:16px;align-items:flex-end;
  height:30px;margin-bottom:2px;
  position:relative;z-index:4;
}
.sl{
  width:3px;border-radius:3px;
  background:#F5C887;opacity:0;
  animation:steamUp 2.4s ease-in-out infinite;
}
@keyframes steamUp{
  0%{transform:translateY(0) scaleX(1);opacity:0;}
  25%{opacity:0.4;}
  100%{transform:translateY(-26px) scaleX(0.1);opacity:0;}
}

.drips-row{display:flex;gap:0;position:relative;width:280px;height:22px;margin-top:-2px;}
.drip{
  position:absolute;
  border-radius:0 0 50% 50%;
  background:#3D1808;
  animation:dripMove 2.6s ease-in-out infinite;
}
@keyframes dripMove{
  0%,100%{transform:scaleY(1);opacity:0.7;}
  55%{transform:scaleY(1.45);opacity:1;}
}

.choco-hint{
  font-family:'Dancing Script',cursive;
  font-size:13px;color:#8B4010;
  margin-top:18px;
  animation:blink 2.5s ease-in-out infinite;
}

/* ========== MESSAGE OVERLAY ========== */
.msg-overlay{
  position:fixed;inset:0;z-index:100;
  background:rgba(8,3,1,0.95);
  display:none;
  align-items:center;justify-content:center;
  padding:24px;
}
.msg-overlay.on{display:flex;animation:fadeOv 0.35s ease;}
@keyframes fadeOv{from{opacity:0;}to{opacity:1;}}

.msg-card{
  background:#2A0E04;
  border:1.5px solid #8B4513;
  border-radius:26px;
  max-width:315px;width:100%;
  position:relative;overflow:hidden;
  animation:popIn 0.42s cubic-bezier(.34,1.56,.64,1);
}
@keyframes popIn{from{transform:scale(0.55) translateY(30px);opacity:0;}to{transform:none;opacity:1;}}

/* CHOCOLATE RIVER */
.choco-river{
  position:absolute;top:0;left:0;width:100%;
  height:0;background:#5C2810;z-index:10;
  pointer-events:none;
}
.choco-river.flow{animation:riverDrop 1.4s cubic-bezier(.4,0,.2,1) forwards;}
@keyframes riverDrop{
  0%{height:0;opacity:1;}
  55%{height:115%;}
  80%{height:115%;opacity:1;}
  100%{height:115%;opacity:0;}
}

.river-top{
  display:flex;justify-content:space-around;
  position:sticky;top:0;width:100%;
}
.rd{
  width:16px;background:#3D1808;
  border-radius:0 0 50% 50%;
  animation:rdDrop 1.1s ease-in-out infinite;
}
@keyframes rdDrop{0%,100%{height:10px;}55%{height:20px;}}

.msg-inner{
  padding:32px 26px 28px;
  position:relative;z-index:12;
  text-align:center;
}

.msg-flowers{
  display:flex;justify-content:center;gap:4px;
  font-size:22px;margin-bottom:14px;
  animation:heartBeat 2s ease-in-out infinite;
}

.msg-title{
  font-family:'Dancing Script',cursive;
  font-size:30px;font-weight:700;
  color:#F5C887;
  margin-bottom:16px;
  text-shadow:0 0 16px rgba(245,200,135,0.35);
  line-height:1.1;
}

.msg-body{
  font-family:'Playfair Display',serif;
  font-style:italic;
  font-size:13.5px;
  line-height:1.9;
  color:#E8C89A;
  margin-bottom:24px;
}

.msg-line{
  height:1px;
  background:linear-gradient(to right,transparent,#8B4513,transparent);
  margin:0 0 20px;
}

.msg-btn{
  background:transparent;
  border:1.5px solid #8B4513;
  color:#F5C887;
  border-radius:50px;
  padding:13px 36px;
  font-family:'Dancing Script',cursive;
  font-size:16px;
  font-weight:600;
  cursor:pointer;
  letter-spacing:0.04em;
  transition:all 0.2s;
}
.msg-btn:hover{background:#3D1808;transform:scale(1.04);}

.bits{position:absolute;inset:0;pointer-events:none;z-index:20;overflow:hidden;border-radius:26px;}
.bit{position:absolute;border-radius:3px;animation:bitFly linear forwards;}
@keyframes bitFly{
  0%{opacity:1;transform:translate(0,0) rotate(0);}
  100%{opacity:0;transform:translate(var(--bx),var(--by)) rotate(600deg);}
}

/* FALLING PETALS */
.petals-fixed{position:fixed;inset:0;pointer-events:none;z-index:1;overflow:hidden;}
.petal{
  position:absolute;top:-20px;
  border-radius:50% 50% 40% 40%;
  opacity:0;
  animation:petalFall linear infinite;
}
@keyframes petalFall{
  0%{transform:translateY(-20px) rotate(0deg);opacity:0;}
  8%{opacity:0.65;}
  90%{opacity:0.4;}
  100%{transform:translateY(105vh) rotate(400deg);opacity:0;}
}
</style>
