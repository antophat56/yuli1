<div class="msg-overlay" id="msgOverlay" onclick="overlayClick(event)">
  <div class="msg-card" id="msgCard">
    <div class="choco-river" id="chocoRiver">
      <div class="river-top">
        <div class="rd" style="animation-delay:0s;"></div>
        <div class="rd" style="animation-delay:0.12s;"></div>
        <div class="rd" style="animation-delay:0.28s;"></div>
        <div class="rd" style="animation-delay:0.08s;"></div>
