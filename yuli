        <div class="rd" style="animation-delay:0.05s;"></div>
        <div class="rd" style="animation-delay:0.18s;"></div>
      </div>
    </div>
    <div class="bits" id="bits"></div>
    <div class="msg-inner">
      <div class="msg-flowers">TE QUIERO MUCHO</div>
      <p class="msg-title">Yuli,<br>eres mi todo</p>
      <div class="msg-line"></div>
      <p class="msg-body">
        Como las rosas mas hermosas del jardin y el chocolate mas dulce del mundo, tu haces que cada dia valga la pena. Tu sonrisa ilumina todo lo que te rodea, y tu corazon es tan calido como el sol de un girasol.
        <br><br>
        Gracias por ser tan especial, tan unica, tan tu. Te mereces todo lo bonito de este mundo y mucho mas.
      </p>
      <button class="msg-btn" onclick="closeMsg()">Con todo mi amor </button>
    </div>
  </div>
</div>

<script>
const starsEl=document.getElementById('stars');
for(let i=0;i<65;i++){
  const s=document.createElement('div');
  s.className='star';
  const sz=Math.random()*2.2+0.6;
  s.style.cssText=`width:${sz}px;height:${sz}px;left:${Math.random()*100}%;top:${Math.random()*100}%;animation-duration:${1.8+Math.random()*3.5}s;animation-delay:${Math.random()*5}s;`;
  starsEl.appendChild(s);
}

const petalEl=document.getElementById('petals');
const pCols=['#E24B4A','#ED93B1','#F4C0D1','#D4537E','#EF9F27','#FAC775','#F09595'];
for(let i=0;i<22;i++){
  const p=document.createElement('div');
  p.className='petal';
  const sz=Math.random()*9+5;
  p.style.cssText=`width:${sz}px;height:${sz+3}px;left:${Math.random()*100}%;background:${pCols[i%pCols.length]};transform:rotate(${Math.random()*360}deg);animation-duration:${9+Math.random()*9}s;animation-delay:${Math.random()*12}s;`;
  petalEl.appendChild(p);
}

const sprkEl=document.getElementById('sparks');
const spCols=['#F5C887','#E05030','#fff','#FFD700','#ED93B1','#EF9F27'];
for(let i=0;i<14;i++){
  const sp=document.createElement('div');
  sp.className='spark';
  const a=Math.random()*Math.PI*2;
  const d=30+Math.random()*40;
  const sz=Math.random()*5+2.5;
  sp.style.cssText=`
    width:${sz}px;height:${sz}px;
    position:absolute;
    left:${38+Math.random()*24}%;
    top:${-40+Math.random()*30}px;
    background:${spCols[i%spCols.length]};
    --tx:${Math.cos(a)*d}px;
    --ty:${Math.sin(a)*d}px;
    animation-duration:${1.2+Math.random()*1.3}s;
    animation-delay:${Math.random()*2}s;
  `;
  sprkEl.appendChild(sp);
}

function openMsg(){
  const ov=document.getElementById('msgOverlay');
  ov.classList.add('on');
  ov.style.display='flex';
  setTimeout(()=>{
    const r=document.getElementById('chocoRiver');
    r.classList.add('flow');
    shootBits();
  },180);
}

function shootBits(){
  const c=document.getElementById('bits');
  c.innerHTML='';
  const cols=['#8B4513','#C87840','#F5C887','#E05030','#3D1808','#6B2E0A','#FAC775'];
  for(let i=0;i<30;i++){
    const b=document.createElement('div');
    b.className='bit';
    const a=Math.random()*Math.PI*2;
    const d=80+Math.random()*150;
    const sz=Math.random()*10+4;
    b.style.cssText=`
      width:${sz}px;height:${sz}px;
      position:absolute;
      left:${30+Math.random()*40}%;
      top:${20+Math.random()*30}%;
      background:${cols[i%cols.length]};
      --bx:${Math.cos(a)*d}px;
      --by:${Math.sin(a)*d}px;
      animation-duration:${0.8+Math.random()*0.7}s;
      animation-delay:${Math.random()*0.3}s;
    `;
    c.appendChild(b);
    setTimeout(()=>b.remove(),1800);
  }
}

function closeMsg(){
  const ov=document.getElementById('msgOverlay');
  ov.style.transition='opacity 0.3s';
  ov.style.opacity='0';
  setTimeout(()=>{
    ov.style.display='none';
    ov.style.opacity='';
    ov.style.transition='';
    ov.classList.remove('on');
    const r=document.getElementById('chocoRiver');
    r.classList.remove('flow');
  },320);
}

function overlayClick(e){
  if(e.target===document.getElementById('msgOverlay')) closeMsg();
}
</script>
